## A streamlined .gitignore for modern .NET projects
## including temporary files, build results, and
## files generated by popular .NET tools. If you are
## developing with Visual Studio, the VS .gitignore
## https://github.com/github/gitignore/blob/main/VisualStudio.gitignore
## has more thorough IDE-specific entries.
##
## Get latest from https://github.com/github/gitignore/blob/main/Dotnet.gitignore

# Build results
csharp/[Dd]ebug/
csharp/[Dd]ebugPublic/
csharp/[Rr]elease/
csharp/[Rr]eleases/
csharp/x64/
csharp/x86/
csharp/[Ww][Ii][Nn]32/
csharp/[Aa][Rr][Mm]/
csharp/[Aa][Rr][Mm]64/
csharp/bld/
csharp/[Bb]in/
csharp/[Oo]bj/
csharp/[Ll]og/
csharp/[Ll]ogs/

# .NET Core
csharp/project.lock.json
csharp/project.fragment.lock.json
csharp/artifacts/

# ASP.NET Scaffolding
csharp/ScaffoldingReadMe.txt

# NuGet Packages
csharp/*.nupkg
# NuGet Symbol Packages
csharp/*.snupkg

# Others
csharp/~$*
csharp/*~
csharp/CodeCoverage/

csharp/# MSBuild Binary and Structured Log
csharp/*.binlog

# MSTest test Results
csharp/[Tt]est[Rr]esult*/
csharp/[Bb]uild[Ll]og.*

# NUnit
csharp/*.VisualState.xml
csharp/TestResult.xml
csharp/nunit-*.xml
csharp/.vs

# Added by cargo

/target
